## check: 048_compare_methods.cro -a1e-10
## delete: 048_compare_methods_gen.scf.in
## labels: regression quick nodata

# compare a crystal against itself with the powder-based methods
# (the emd method is omitted: it overflows the stack via the bundled
#  src/emd/emd.c russel() routine; see comment in this bundle's CMakeLists)
crystal library uracil
write 048_compare_methods_gen.scf.in

compare . 048_compare_methods_gen.scf.in gpwdf
compare . 048_compare_methods_gen.scf.in powder
